{
  "name": "@artsy/palette",
  "version": "46.9.2",
  "description": "Design system library for react components",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "compile": "rslib build",
    "prepack": "yarn generate-tokens && yarn generate-styles",
    "generate-tokens": "ts-node scripts/generate-tokens.ts",
    "generate-styles": "ts-node scripts/generate-styles.ts",
    "lint": "eslint --cache --cache-location '.cache/eslint/' --ext ts,tsx  --ignore-pattern 'dist'",
    "local-palette-dev": "scripts/yalc-sync-after-change",
    "prepublishOnly": "yarn clean && cd ../palette-tokens && yarn compile && cd ../palette && yarn compile",
    "prettier-project": "yarn prettier --write 'src/**/*.{ts,tsx}'",
    "release": "auto shipit && node scripts/clean-up-after-auto.js",
    "test": "yarn type-check && yarn jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "type-check": "tsc --noEmit --pretty",
    "type-declarations": "rslib build",
    "watch": "rslib build --watch",
    "storybook": "storybook dev -p 6006 --quiet",
    "build-storybook": "storybook build",
    "visual-test": "chromatic test --exit-zero-on-changes --project-token n02zjqmdqq"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/artsy/palette.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/artsy/palette/issues"
  },
  "homepage": "https://github.com/artsy/palette#readme",
  "peerDependencies": {
    "@artsy/icons": "^3.0.0",
    "react": "^18",
    "react-dom": "^18",
    "styled-components": "^6"
  },
  "devDependencies": {
    "@artsy/auto-config": "1.3.0",
    "@artsy/icons": "^3.64.0",
    "@rsbuild/core": "^1.7.4",
    "@rsbuild/plugin-styled-components": "^1.6.1",
    "@rslib/core": "^0.20.1",
    "@storybook/addon-a11y": "^9.1",
    "@storybook/addon-docs": "^9.1",
    "@storybook/addon-links": "^9.1",
    "@swc/core": "^1.15.21",
    "@swc/jest": "^0.2.39",
    "@types/debounce": "1.2.0",
    "@types/enzyme": "3.10.8",
    "@types/jest": "^28.0.0",
    "@types/node": "14.14.27",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-test-renderer": "16.8.1",
    "@types/semver": "5.5.0",
    "@types/styled-system": "5.1.9",
    "@types/styled-system__theme-get": "5.0.0",
    "@typescript-eslint/eslint-plugin": "^4.31.1",
    "@typescript-eslint/parser": "^4.31.1",
    "@wojtekmaj/enzyme-adapter-react-17": "0.4.1",
    "chromatic": "5.9.2",
    "concurrently": "4.1.0",
    "enzyme": "3.9.0",
    "enzyme-to-json": "3.3.5",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-react": "^7.25.3",
    "eslint-plugin-react-hooks": "^4.2.0",
    "eslint-plugin-storybook": "^9.0",
    "husky": "2.1.0",
    "jest": "^28.0.0",
    "jest-environment-jsdom": "^29.5.0",
    "jest-styled-components": "7.2.0",
    "lint-staged": "8.1.5",
    "mock-raf": "1.0.1",
    "nodemon": "^2.0.22",
    "prettier": "2.2.1",
    "react": "^18.3.1",
    "react-17": "npm:react@17.0.2",
    "react-dom": "^18.3.1",
    "react-dom-17": "npm:react-dom@17.0.2",
    "react-powerplug": "1.0.0",
    "react-test-renderer": "16.8.6",
    "storybook": "^9.1",
    "storybook-react-rsbuild": "^2",
    "storybook-states": "1.2.0",
    "styled-components": "6.1.13",
    "ts-node": "8.1.0",
    "typescript": "^5.8.3",
    "typescript-styled-plugin": "0.10.0"
  },
  "dependencies": {
    "@artsy/palette-tokens": "^7.3.0",
    "@floating-ui/react": "^0.27.18",
    "@seznam/compose-react-refs": "^1.0.6",
    "@styled-system/theme-get": "^5.1.2",
    "es-toolkit": "^1.16.0",
    "proportional-scale": "^4.0.0",
    "react-focus-on": "^3.7.0",
    "styled-system": "^5.1.5",
    "use-cursor": "^1.2.3",
    "use-keyboard-list-navigation": "2.4.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "yarn run type-check"
    }
  },
  "lint-staged": {
    "*.@(ts|tsx)": [
      "yarn lint --fix",
      "yarn prettier --write",
      "git add"
    ]
  },
  "prettier": {
    "semi": false,
    "singleQuote": false,
    "trailingComma": "es5",
    "bracketSpacing": true
  },
  "jest": {
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "json"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/dist/*"
    ],
    "moduleDirectories": [
      "node_modules",
      "<rootDir>/src"
    ],
    "moduleNameMapper": {
      "^react$": "react-17",
      "^react-dom$": "react-dom-17",
      "^react-dom/test-utils$": "react-dom-17/test-utils"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/src/utils/jestShim.js",
      "<rootDir>/setupTests.ts"
    ],
    "snapshotSerializers": [
      "enzyme-to-json/serializer"
    ],
    "transform": {
      ".(ts|tsx)": [
        "@swc/jest",
        {
          "jsc": {
            "parser": {
              "syntax": "typescript",
              "tsx": true
            },
            "transform": {
              "react": {
                "runtime": "automatic"
              }
            },
            "externalHelpers": false
          },
          "module": {
            "type": "commonjs",
            "importInterop": "swc"
          }
        }
      ]
    },
    "testEnvironment": "jsdom",
    "testRegex": "(/__tests__/.*|\\.(test|spec))\\.(ts|tsx|js|jsx)$",
    "testPathIgnorePatterns": [
      "<rootDir>/dist/",
      "<rootDir>/www/"
    ],
    "testEnvironmentOptions": {
      "url": "http://localhost"
    }
  }
}
